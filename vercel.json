{
  "version": 2,
  "installCommand": "npm install --omit=optional && cd client && npm install && cd ../server && npm install --omit=optional",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/.*",
      "dest": "/api/index.js"
    },
    {
      "src": "/.*",
      "dest": "/client/dist/index.html",
      "status": 200
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}

